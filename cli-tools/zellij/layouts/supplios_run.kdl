layout {
    tab name="docker-runners" cwd="~/Supplios/supplios-app/django_app/" {
        pane split_direction="vertical" {
            pane size="35%" {
                pane {
                    command "make"
                    args "attach-to-web"
                    close_on_exit true
                }
            }
            pane split_direction="horizontal" size="45%" {
                pane {
                    command "make"
                    args "run-django"
                }
                pane {
                    cwd "~/Supplios/supplios-app/django_app/_frontend"
                    command "npm"
                    args "run" "build-lib-watch"
                }
            }
            pane split_direction="horizontal" size="20%" {
                pane {
                    command "make"
                    args "run-celery-worker"
                }
                pane {
                    command "make"
                    args "run-celery-beat"
                }
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
}
